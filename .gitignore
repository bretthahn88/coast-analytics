# loose media files at the repo root only -- canonical copies live in
# client/public/ (images/, videos/) and stay tracked. The leading "/"
# anchors each pattern to the repo root so subdirectories aren't affected.
/*.webp
/*.mp4
/*.mov
/*.png
/*.jpg
/*.jpeg
