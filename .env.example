# Coast Analytics, environment variables
# Copy this file to .env and fill in real values for local development.
# On Vercel, set the same keys in Project > Settings > Environment Variables.

# Demo gate password (informational, the demo is gated by the email-capture form, not a password)
DEMO_PASSWORD=ilp2026

# Admin panel password, required for /admin lead viewer
ADMIN_PASSWORD=ilpadmin2026

# Klaviyo integration (used by the demo gate)
# Private API key from https://www.klaviyo.com/account#api-keys-tab
# Set KLAVIYO_LIST_ID to the list that should receive Coast Analytics subscribers.
KLAVIYO_API_KEY=pk_your_klaviyo_private_api_key_here
KLAVIYO_LIST_ID=

# Server config (local dev only, Vercel sets these automatically)
PORT=3001
NODE_ENV=development

# Database path (SQLite). On Vercel serverless, /tmp is the only writable location.
DB_PATH=./server/db/ilp.sqlite

# Optional Python ML service. If unreachable, JS heuristic scoring is used.
ML_SERVICE_URL=http://127.0.0.1:5005

# CORS origin for local Vite dev server
CLIENT_ORIGIN=http://localhost:5173

# Formspree form ID for the contact / consultation form. The code wraps
# this with the formspree.io prefix, so set ONLY the hash from the
# Formspree dashboard URL, not the full URL. Defaults to mwvzkdbq.
# VITE_CONSULTATION_FORMSPREE=mwvzkdbq
